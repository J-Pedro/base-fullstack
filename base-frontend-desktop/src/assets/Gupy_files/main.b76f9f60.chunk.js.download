ptions_aria_label":"Options of education level status","new_education_page_title":"<strong>Add education</strong>","curriculum/pages/profile/components/location-form/address-zip-code-label":"ZIP code *","curriculum/pages/profile/components/location-form/address-zip-code-aria-label":"","curriculum/pages/profile/components/location-form/address-city-aria-label":"","curriculum/pages/profile/components/location-form/address-zip-code-placeholder":"","curriculum/pages/profile/components/location-form/inter-address-zip-code-aria-label":"","curriculum/pages/profile/components/location-form/address-street-label":"Address *","curriculum/pages/profile/components/location-form/address-street-aria-label":"","curriculum/pages/profile/components/location-form/address-city-label":"City *","curriculum/pages/profile/components/location-form/inter-address-city-label":"State / Province / Region *","curriculum/pages/profile/components/location-form/inter-address-city-aria-label":"","curriculum/pages/profile/components/location-form/address-state-label":"State *","curriculum/pages/profile/components/location-form/address-state-aria-label":"","curriculum/pages/profile/components/location-form/address-country-aria-label":"","curriculum/pages/profile/components/location-form/location":"Address","curriculum/pages/profile/components/location-form/location-description":"Remember, this address will be used in all your applications","curriculum/pages/profile/components/location-form/spinner-label":"","curriculum/pages/profile/components/profile-details/telephone":"Landline","phone_number":"Landline","curriculum/pages/profile/components/profile-details/empty":"Unreported data","curriculum/pages/profile/components/profile-details/details-footer-text":"If personal data is out of date","curriculum/pages/profile/components/profile-details/details-footer-link":"make adjustments to your profile","curriculum/pages/profile/components/social-form/aria-label":"","curriculum-pages-profile-title":"<b>My identity</b>: Profile","unlimited":"Unlimited","time_left":"Time left","time_is_up":"Time is up","send_test":"Send test","time_is_up_message":"You have reached the time limit for the test. Your test will be sent for evaluation with all answers already informed so far.","custom_tests_question_of":"Question {step} out of {total}","required_answer":"Required answer","save_answer_and_finish_test":"Finish assessment","reuse_offer_back":"Back to the selection process steps","custom_tests_warning_interruption":"Make sure you set aside <strong>enough time</strong> to take the test without interruptions. If you leave the test without finishing, the test will be considered completed and <strong>you will not be able to do it again.</strong>","custom_tests_warning-time":"","custom_tests_need_help":"If in doubt,","reuse_completion_info_doubt":"If in doubt,","custom_tests_need_help_consult":"consult the help center.","reuse_completion_info_link":"consult the help center.","custom_tests_start_test":"Start answering","reuse_completion_title":"Test successfully reused!","reuse_completion_body":"You chose to proceed with the score of the test carried out on","reuse_completion_conclude_button":"Conclude","reuse_offer_date":"You answered this test on","reuse_offer_company_begin":"","reuse_offer_company_end":"","reuse_offer_tip":"You can reuse the test result by clicking reuse score or start a new test which will replace the existing one.","reuse_offer_reuse":"Reuse score","reuse_offer_redo":"Start new test","email_reset_title":"Email change","email_reset_description":"If you\u2019ve lost access to the email provided and want to change it,","email_reset_description_bold":"fill in the fields below.","error-404":"Oops! The page you are looking for was not found.","error-500":"Oops! Something unusual has happened with our servers. We will be back soon!","forgot_password_success_email_message":"Check the inbox of the email {emailAddress}","forgot_password_success_id_message":"If there is a registration with Gupy for the document informed, we will send a link to the email registered in it.","send":"Send instructions to e-mail","forgot_password_description":"Enter your email or Personal Documentation Number to reset password.","forgot_password__id_description":"Enter your CPF and we\u2019ll send you a link to reset your password","forgot_password_remember":"Can\u2019t remember the e-mail you registered?","forgot_password_redefine_id":"Redefine password with Personal Documentation Number","forgot_password_remember_id":"Can\u2019t remember the CPF you registered?","forgot_password_redefine_email":"Redefine password with e-mail","forgot_password_send_link":"Send link by email","forgot_password_success_title":"Verification link sent","forgot_password_options_success_title":"Verification link sent","forgot_password_notiecs_email":"Make sure the email address or taxpayer registry is the same email or personal documentation number  used in Gupy's selection processes.","dont_receive_email_help":"I still haven't received the email, what could have happened?","forgot_password_options_dont_receive_email_help":"I still haven't received the email, what could have happened?","forgot_password_options_dont_receive_email_title":"I still haven't received the email, what could have happened?","dont_receive_email_title":"I didn't receive the reset email, what to do?","dont_receive_email_description":"If you didn't receive the password reset email, please follow these steps carefully:","dont_receive_email_tip1":"Verify if you have received the email with the subject of <strong>Reset Password</strong> from <strong>Gupy Sender.</strong>","dont_receive_email_tip2":"<strong>Verify if the email is spelled correctly!</strong> We recommend that you type the email address manually, without any capital letters or spaces;","dont_receive_email_tip3":"Make sure that the <strong>email</strong> you entered <strong>is the same one registered when registering with Gupy;</strong>","dont_receive_email_tip4":"<strong>Check your SPAM or Junk E-mail box.</strong> It could be that your email did not recognize the Gupy domain and the reset email was marked suspicious;","dont_receive_email_tip5":"<strong>Don't try to reset the password several times in a row.</strong> Every time you click send link, the platform sends a new message to your email and the previous reset button expires, that is, if you click on reset password several times, many links will be generated and it will not be possible to know which one is correct.","dont_receive_email_contact_us":"","forgot_password_options_dont_receive_link":"Didn't receive the link?","forgot_password_dont_recognize_contact_options":"Doesn't recognize or doesn't have access to the contact options?","forgot_password_options_choose_option":"Choose one of the options below to reset your password:","forgot_password_options_success_spam_tip":"If it's not in the inbox, remember to check the Spam.","forgot_password_options_reset_via_email":"Reset password via E-mail","forgot_password_options_reset_via_sms":"Reset password via SMS","forgot_password_notices_email":"Make sure the email address or taxpayer registry is the same email or personal documentation number used in Gupy's selection processes.","forgot_password_sms_sent_recently":"Recently sent sms. Try again later.","forgot_password_sms_send_error":"Unexpected error sending SMS","email_token_already_requested":"You have already requested a password reset. If you still need it, try again in 1 minute.","forgot_password_options_dont_receive_email_description":"If you didn't receive the password reset email, please follow these steps carefully:","forgot_password_options_dont_receive_email_tip1":"Make sure that the <strong>email you entered is the same one registered</strong> when registering with Gupy;","forgot_password_options_dont_receive_email_tip2":"<strong>Check your SPAM or Junk E-mail box.</strong> It could be that your email did not recognize the Gupy domain and the reset email was marked suspicious;","forgot_password_options_dont_receive_email_tip3":"<strong>Do not try to reset your password multiple times in a row,</strong> wait a few minutes before trying again. Every time you click on send link, the platform sends a new message to your email and the previous reset button expires.","forgot_password_options_dont_receive_email_contact_us":"Still unable to reset your password? Click <strong><u><a href=https://suporte-candidatos.gupy.io/s/suporte?language=pt_BR>submit request</a></u></strong> to speak to our support team, they are ready to help you!","forgot_password_options_has_reached_sms_resend_limit":"You have reached the <b>attempt limit</b> for resetting your password via <b>SMS</b> and for your security, we are blocking this functionality <b>for 24 hours</b>. You can still reset <b>by email</b> or contact <strong><u><a href=https://suporte-candidatos.gupy.io/s/suporte?language=pt_BR>support time here</a></u></strong>.","forgot_password_options_unregistered_phone_number":"No registered number","reset_email_access":"Don\u2019t have access to this email? Click here.","no_permission":"No permission","forbidden_title":"Oops! It looks like you don't have permission to view this page.","forbidden_description":"Contact your company's human resources department, or access the opportunities tab to view public jobs now.","go_to_opportunities":"Go to opportunities","job_details_description":"Job Description","job_details_responsabilities":"Main responsibilities","job_details_prerequisities":"Requirements and skills","job_details_handicapped":"Opportunity also for persons with disabilities","job_details_apply":"Apply","job_details_back_to_internal_jobs":"","vacancy_type_apprentice":"Apprentice","job_previewer-vacancy_type_apprentice":"Apprentice","vacancy_type_associate":"Associate","job_previewer-vacancy_type_associate":"Associate","vacancy_type_talent_pool":"Talent pool","vacancy_type_lecturer":"Lecturer","job_previewer-vacancy_type_lecturer":"Lecturer","vacancy_type_effective":"Full-time employee","job_previewer-vacancy_type_effective":"Full-time employee","vacancy_type_internship":"Internship","job_previewer-vacancy_type_internship":"Internship","vacancy_legal_entity":"Legal person","vacancy_type_summer":"Summer Job","job_previewer-vacancy_type_summer":"Summer Job","vacancy_type_parter":"Partner","job_previewer-vacancy_type_partner":"Partner","vacancy_type_temporary":"Temporary","job_previewer-vacancy_type_temporary":"Temporary","vacancy_type_outsource":"Third party","job_previewer-vacancy_type_outsource":"Third party","vacancy_type_trainee":"Trainee","job_previewer-vacancy_type_trainee":"Trainee","vacancy_type_volunteer":"Volunteer","job_previewer-vacancy_type_volunteer":"Volunteer","vacancy_type_autonomous":"Self-employed","job_previewer-vacancy_type_autonomous":"Self-employed","vacancy_type_freelancer":"Freelancer","job_previewer-vacancy_type_freelancer":"Freelancer","internal_jobs_content_title":"Oops, no available opportunities","opportunities_empty_content_title":"Oops, no available opportunities","internal_jobs_empty_content_text":"Come back later to check new opportunities.","opportunities_empty_content_text":"Come back later to check new opportunities.","see_details_button_text":"See more details","job_tooltip_recommeded":"Based on your profile and areas of interest.","internal_jobs_empty_content_company_text":"It seems like {currentCompany} does not have have open job postings at the moment.","opportunities_empty_content_company_text":"It seems like {currentCompany} does not have have open job postings at the moment.","job_previewer-employee-admission":"","job_previewer-employee-readmission":"","job_previewer-employee-reintegration":"","job_previewer-employee-hiring":"","job_previewer-employee-transfer":"","job_previewer-vacancy_type_talent_pool":"","job_previewer-vacancy_legal_entity":"","view_offer_error":"","job_offer_title":"","job_offer_description":"","job_offer_current":"","job_offer_status_accepted":"","job_offer_status_rejected":"","error_sending_email":"Email failed to send.","attachments":"Attachments","this_job_is_closed":"This job posting is closed","reply_not_allowed_by_company":"This company has chosen not to receive replies for this message.","attach_files_label":"","attach_files_description":"Unlimited files up to 25MB","invalid_files_total_size_25mb":"Your upload failed. Files must not exceed 25MB.","file_error_message":"Error uploading file.","sending_email":"Sending email\u2026","messages_empty_content_title":"It seems like you haven\u2019t received any messages yet","messages_empty_content_text":"You will also be notified on your e-mail whenever you have new messages.","messages_empty_content_company_text":"During your processes, {currentCompany} may start a conversation with you.","interview_event_canceled":"This event has been canceled","my_admissions_description_a":"Track your progress in the admission process for the jobs you are in the hiring stage.","my_admissions_description":"Track your progress in the admission process for the jobs you are in the hiring stage.","my_admissions_empty":"You don\u2019t have admissions yet.","my_admissions_card_in_progress":"Admission in progress","admission_card_in_progress":"Admission in progress","my_admissions_card_completed":"Admission completed in","admission_card_completed":"Admission completed in","my_admissions_card_send_documents":"Send documents","my_application_send_documents":"Send documents","admission_card_send_documents":"Send documents","my_admissions_card_send_documents_warning":"Submit your documents by","admission_card_send_documents_warning":"Submit your documents by","my_admissions_card_review_admission":"Review admission","admission_card_review_admission":"Review admission","this_vacancy_has_been_closed":"This job posting has been closed","your_application_has_been_closed":"Your application has been closed","check_progress":"See progress","delete_job":"Delete job","my_applications_quit_application_confirmation_title":"Withdraw from this job posting","my_applications_quit_application_confirmation_message":"This action cannot be undone. Confirm withdrawal","your_application_on_this_vacancy_has_been_closed":"Your application for this position has been closed","unfortunately_you_dont_have_all_requisites":"Unfortunately you do not have all the necessary requirements for this position at this time. Therefore, your application has been closed by the company. But don't be discouraged! Follow new jobs on the Opportunities page.","my_application_description":"Follow and manage the job postings you have applied for.","my_invited_applications_title":"Jobs you have been added","my_applied_applications_title":"Jobs you have applied for","invitation":"Invitation","my_application_ops":"Oops!","profile_test_confirmation_title":"Oops!","my_application_cannot_withdraw_application":"It is not possible to give up this vacancy. Please contact the recruiter for more information.","your_application_has_been_removed":"Your application has been successfully removed!","empty_content_title":"It seems like you don\u2019t have applications yet","empty_content_apply":"Apply for jobs and access here your applications at {currentCompany} ","empty_content_link_text":"Access opportunities page of {currentCompany}","opportunities_card_recommended":"Recommended for you","opportunities_description":"See other opportunities in this company.","opportunities_card_btn_apply":"Apply","apply_for_the_job":"Apply for the vacancy","profile_test_conclusion_title":"Test results","profile_test_conclusion_new_description":"You have finished the profile assessment. Click on \u201CFinish\u201D to see your results or come back later to review it.","profile_test_introduction_title":"Instructions to perform the profile assessement","profile_test_introduction_first_paragraph":"The profile assessment allows you to know more about your skills and capabilities, and enables us to help you with your self-knowledge process.","profile_test_introduction_second_paragraph":"The criteria used in this assessment were defined from researches and statistical calculations in order to give a higher reliability to the process. Therefore, answer according to who you really are and not to who you would like to be.","profile_test_introduction_third_paragraph":"The more you know yourself and the more truthful you are in your answers, the more accurate your results will be. It's fast! The assessment is divided in two parts with 22 questions, and in 15 minutes you will know your profile and style of work.","profile_test_slide_intro_title":"Part 1","profile_test_slide_intro_desc":"Distribute the points according to your level of preference. The sum of the alternatives must always be 3.","profile_test_slide_intro_description":"You have 3 points and need to distribute them according to their level of importance","profile_test_topic2_title":"Part 2","profile_test_topic2_description":"On this step you need to set a level of importance for the following situations.","profile_test_topic2_more_relevant_description":"Place the most relevant option on top","profile_test_topic2_less_relevant_description":"Place the least relevant option on the bottom","profile_test_topic1_description":"Drag up and down and set a relevance order for you","more_relevant":"Most relevant","less_relevant":"Least relevant","undefined-test-resul-modal-title":"Important information about your profile assessment","undefined-test-resul-modal-message-part1":"It was not possible to set a profile by your assessment results. Do not worry, this may happen sometimes. :)","undefined-test-resul-modal-message-part2-1":"In order to solve this, we ask you to retake your test thinking about what would be your actions and preferences in the following situations,","undefined-test-resul-modal-message-part2-2":"even if you haven't gone through the same experiences presented in the questions.","undefined-test-resul-modal-message-part3":"Think about the questions once again, and when you finish your assessment, you will have a profile set out that will help you understand more about yourself!","undefined-test-resul-modal-confirm":"Ok, try again","profile_test__confirmation_message":"You need to distribute the 3 points before continuing","ok":"Ok","unbind_company_know_more_dialog_action":"Ok","profile_test_loading":"Loading Profile Assessment\u2026","profiles":"Profiles","individuality":"Individuality","organization":"Organization","holder":"Support","flexibility":"Flexibility","test-result__title":"Profile assessment result","test-result__description":"The results you will see here show your preferences in the four categories we have. More extreme results indicate clearer preferences. You shouldn't look for a balance, but for the understanding of your profile.","profile_test_result_not_found":"Profile assessment result not found","you_profile_is":"Your main profile is:","read_more":"Read more","profile_description":"Profile description","profile_env_work":"Work environment","remunaration_system":"Compensation system","accept_cookie_text":"We use cookies and similar technologies to improve your experience on our services. By continuing to browse, you agree to these conditions.","accept_cookie_button_text":"Proceed","usage_terms_title":"GUPY FOR APPLICANTS TERMS AND CONDITIONS OF USE","usage_terms_introduction_paragraph1":"Hello! These Terms and Conditions (\\"Terms\\") apply to the use of the platform and services offered by GUPY TECNOLOGIA EM RECRUTAMENTO LTDA, manager of the website www.gupy.io and the GUPY application (together referred as \\"GUPY Platform\\") and provider of the services object of these Terms (\\"Services\\").","usage_terms_introduction_paragraph2":"The acceptance of these Terms is indispensable to the use of the GUPY Platform and the Services. Therefore, for the correct use, You must read, make sure you have understood and accept all the conditions set forth in these Terms.","usage_terms_topic1":"1. Definitions","usage_terms_topic1_paragraph1":"To use the Platform and Services, you, the Candidate, must be at least 14 years of age. To enter into contracts with THE COMPANY you must have full capacity under the laws of your country, i.e. be over 18 years of age or be 14 years of age and have the consent of your parents or legal guardian.","usage_terms_topic1_paragraph2":"COMPANIES are companies that use the GUPY Platform to publicize job opportunities or to capture a talent pool to identify potential talent among them, selecting them to join their team.  The openings will be disclosed in the \\"Work with Us\\" area of the careers page of the COMPANY's website.","usage_terms_topic1_paragraph3":"For the purposes of these Terms, when we use the term USERS we are referring to You, to the Candidates in general and to the COMPANIES.","usage_terms_topic2":"2. Changes","usage_terms_topic2_paragraph1":"These Terms may be modified from time to time for valid reasons. Whenever there is a relevant change, GUPY will use its best efforts to communicate You and request a new acceptance of the most current version. However, we ask that You visit this page periodically to check the most recent Terms established for use of the GUPY Platform.","usage_terms_topic3":"3. Application of these Terms","usage_terms_topic3_paragraph1":"These Terms will apply to You once You start using the GUPY Platform by creating a user account and will only cease to apply if your account is cancelled by GUPY or terminated by You. If your account is subsequently reactivated, these Terms will again apply to You in their current version.","usage_terms_topic3_paragraph2":"GUPY may cancel accounts and take all applicable legal action in the event of a violation of these Terms by USERS.","usage_terms_topic4":"4. Services provided by GUPY","usage_terms_topic4_paragraph1":"GUPY offers the following Services for Companies:","usage_terms_topic4_paragraph1_item1":"mapping of the profile of COMPANIES;","usage_terms_topic4_paragraph1_item2":"mapping your profile, potential and knowledge, through the performance of tests provided by GUPY or third parties;","usage_terms_topic4_paragraph1_item3":"combining the profile of the COMPANIES seeking Candidates and Candidates in search of a new job position, with the participation in a recruitment process to be carried out when job opportunities are available.","usage_terms_topic5":"5. Your registration","usage_terms_topic5_item1_title":"Veracity of data.","usage_terms_topic5_item1_description":"Your registration must be done when accessing the GUPY Platform or the COMPANY Platform and will only be confirmed by filling out all the requested fields. By accepting these Terms You undertake to complete the registration with accurate, precise and true information and to update your data whenever there are any changes in them.  You can make corrections or modifications yourself by editing the information in your profile. GUPY will not be responsible for personal data entered incorrectly by Candidates, who may respond civilly and criminally for the truthfulness, accuracy and authenticity of the data registered.","usage_terms_topic5_item2_title":"Access account.","usage_terms_topic5_item2_description":"To use the GUPY Platform, GUPY will make available to You an account, which will be accessed through email (login) and password. It is prohibited to inform third parties of this data and You will be fully responsible for the use that is made of them. In case of unauthorized use of your account, You must inform us immediately by opening a ticket through https://gupy.zendesk.com/hc/pt-br/requests/new, assuming all risks arising from any unauthorized access.","usage_terms_topic5_item3_title":"Access through social networks.","usage_terms_topic5_item3_description":"You may also access your account through social networks that have previously established connection with the GUPY Platform, such as LinkedIn and Facebook. In this case, the data informed in those sites may be subject to terms of use and privacy policies of those sites.","usage_terms_topic5_item4_title":"Registration resulting from the recruitment process.","usage_terms_topic5_item4_description":"Registering as a result of a recruitment process, you will only have access to all the functionalities of the GUPY Platform when the registration process and the test steps made available by the COMPANIES are completed. If you register in more than one recruitment process at the time of registration, you will have access to all the functionalities of the GUPY Platform as soon as you finish the registration steps of one of them. Your registration is unique and will be used in all the recruitment processes in which you register.","usage_terms_topic5_item5_title":"Referral for the job position.","usage_terms_topic5_item5_description":"If, when registering in a certain recruitment process, you inform that you are being referred to the job position by a current employee of the COMPANY that started the recruitment process, the referral must be validated, through the GUPY Platform, by the person who referred you.","usage_terms_topic5_item6_title":"Data sharing.","usage_terms_topic5_item6_description1":"Your data will be treated and stored in the GUPY database in a secure environment, observing available technologies and will be shared with those who need to receive them to make your participation in the selection process viable, that is, with the COMPANIES that are conducting such process. Besides the COMPANY, which will always receive your data, HR or personnel management consulting firms may also conduct the recruiting process, which may (i) open a recruiting process on behalf of the recruiting company; or (ii) manage a recruiting process opened by the recruiting company itself. These COMPANIES may communicate directly with you to conduct the selection process, to invite you to apply for other openings and for related topics.","usage_terms_topic5_item6_description2":"They may also receive your personal information from contractors we hire to help us do our job. For more information about the sharing of your personal information, please see Gupy's Privacy Policy.","usage_terms_topic5_item7_title":"Vacancy Applicant Assignment.","usage_terms_topic5_item7_description":"The COMPANY may invite you, as long as you have previously enrolled in its selection processes, whether these processes are still in progress or not, to participate in selection processes of other open positions that match your profile and skills, always thinking of your benefit and interest in being hired.","usage_terms_topic5_item8_title":"Talent Bank.","usage_terms_topic5_item8_description":"When you apply for a selection process, you become part of the recruiting company's talent bank; your personal data will be kept even after the end of the selection process. At any time, you may request your exclusion, as indicated in our Privacy Policy.","usage_terms_topic6":"6. User Content","usage_terms_topic6_paragraph1":"All information, data, texts, programs, music, sounds, photographs, graphics, videos, advertisements, messages and other materials sent, inserted or displayed by the Candidate or the COMPANY are the sole responsibility of the author of such content.","usage_terms_topic6_paragraph2":"GUPY may take any action it deems necessary or appropriate regarding User Content if it believes that such content may create liability for GUPY, defame its brand or public image, or cause losses to USERS, or their Internet providers or other suppliers (in part or in whole).","usage_terms_topic7":"7. Profile Mapping and Testing","usage_terms_topic7_paragraph1":"In the GUPY Platform you will perform online tests, used to map your profile, potential and general knowledge. The available tests will be performed only once and will be used for all the recruitment processes in which you participate. If you wish, you can retake the tests 6 (six) months after the first attempt (this rule can be changed depending on the recruitment process).","usage_terms_topic7_paragraph2":"The result of the tests will be available only to the COMPANIES in whose recruitment process you register. These results will help the COMPANIES in the selection of Candidates. Any comments or recommendations made regarding these tests by the COMPANY will only be accessible to the COMPANY and the employees assigned by it to use the GUPY Platform.","usage_terms_topic7_paragraph3":"The rules on \\"Data Sharing\\" set forth in item 5 above also apply to this data.","usage_terms_topic8":"8. Video Recording Step","usage_terms_topic8_paragraph1":"The video recording, for those cases where the recruitment process requests it, can be done through the GUPY Platform.","usage_terms_topic8_paragraph2":"The videos must be recorded according to parameters and guidelines pre-established by GUPY.","usage_terms_topic8_paragraph3":"GUPY will remove from the platform any video that, according to its criteria, contains inappropriate content, illegal or that collapses with GUPY's partner companies, in which case the Candidate responsible for the recording will have his/her registration deleted, in addition to being subject to civil and criminal liability for any damage that the video content may cause to third parties.","usage_terms_topic8_paragraph4":"You authorize GUPY to disclose your image, by making the recorded video available to the client COMPANIES.","usage_terms_topic8_paragraph5":"Unlike the tests, the videos will only be used for the recruitment process for which it is recorded and will not be used for future recruitment processes of vacancies opened by other companies.","usage_terms_topic8_paragraph6":"The videos, as well as any comments or recommendations made regarding the videos by the COMPANY will only be accessed by the COMPANY and the employees assigned by it to use the GUPY Platform. The rules on \\"Data Sharing\\" set forth in item 5 above also apply to this data.","usage_terms_topic9":"9. Scheduling of interviews","usage_terms_topic9_paragraph1":"If the COMPANY selects this option, an e-mail can be sent to You indicating the dates available for scheduling an interview. If you select a date, it is up to the COMPANY, not the GUPY, to confirm the appointment.","usage_terms_topic9_paragraph2":"This step occurs only between COMPANY and Candidate and GUPY is not responsible for the attendance of the parties or for the feedback on the interview conducted.","usage_terms_topic10":"10. General Guidelines of the Candidate","usage_terms_topic10_paragraph1":"In the use of the GUPY Platform, the Candidate can:","usage_terms_topic10_paragraph1_item1":"search job offers through filters;","usage_terms_topic10_paragraph1_item2":"share on social networks all the content available within the GUPY platform (website and application) that is available for such action;","usage_terms_topic10_paragraph1_item3":"apply to other job opportunities;","usage_terms_topic10_paragraph1_item4":"alter, rectify or delete your data, in accordance with the Privacy Policy currently available.","usage_terms_topic10_paragraph2":"The Candidate (and the USER in general in what it applies) cannot:","usage_terms_topic10_paragraph2_item1":"include resumes or apply for job opportunities on behalf of third parties;","usage_terms_topic10_paragraph2_item2":"post as \\"public\\" more than one copy of the same resume at a time;","usage_terms_topic10_paragraph2_item3":"violate/attempt to violate GUPY security as an attempt to investigate, copy and test the vulnerability of the system, network, security breach or unauthorized authentication measures;","usage_terms_topic10_paragraph2_item4":"forge TCP/IP headers or any part of the header information in any email or newsgroup posts;","usage_terms_topic10_paragraph2_item5":"aggregating, copying or duplicating parts of the GUPY platform (site and application), including expired job opportunities;","usage_terms_topic10_paragraph2_item6":"adapt or link to any GUPY Content or information available on the Site or Application, unless permitted by this Term;","usage_terms_topic10_paragraph2_item7":"post content or materials that promote or endorse false/misleading information or illegal activities, as well as information that offers instructions for illegal or prohibited activities in accordance with this Agreement;","usage_terms_topic10_paragraph2_item8":"access data of third parties, servers or accounts that you are not authorized to access;","usage_terms_topic10_paragraph2_item9":"publish content that contains pages with restricted access or password, as well as hidden pages or images;","usage_terms_topic10_paragraph2_item10":"harass, incite or defend any type of harassment of any group, company or individual;","usage_terms_topic10_paragraph2_item11":"attempt to interfere with the services to USERS, administrator or network, including but not limited to methods of sending viruses to the site, overloading, accumulation of messages without content, spam, \\"email bomb\\" or crashes;","usage_terms_topic10_paragraph2_item12":"use the GUPY Platform in an unlawful manner for any illegal activity, include or submit any content, resume or job offer that is defamatory, accusatory, implicitly or explicitly offensive, vulgar, obscene, threatening, abusive, angry, racist, discriminatory, and may cause irritation, inconvenience, humiliation, anxiety, and may be considered harassment. Links to sites with pornographic, indecent or explicit sex material of any kind are also not permitted; as determined at the discretion of GUPY.","usage_terms_topic10_paragraph3":"Violations of system and network security may result in civil and/or criminal prosecution. GUPY will investigate occurrences that may result in violations, including, but not limited to those cited above, and may engage and cooperate with authorities and public safety agencies in punishing USERS who commit acts of violation.","usage_terms_topic10_paragraph4":"GUPY reserves the right to remove any job opportunity disclosures or content from the GUPY Platform that, in its sole discretion, are not in accordance with this item or these Terms, as well as content that is not of your interest.","usage_terms_topic10_paragraph5":"In the event that an ideological falsehood or fraud is identified related to the nature of the USER's activities on GUPY Platform, GUPY may, at its discretion, terminate its relationship with the USER.","usage_terms_topic11":"11. Navigation History and User Interaction Recording","usage_terms_topic11_paragraph1":"For proper use of the GUPY Platform, we will record your browsing and interaction history on the GUPY Platform, in order to identify errors and failures, understand your preferences to improve the platform and create new products, enable the offer of better content, as well as meet legal and administrative needs in case of fraud or court order. To learn more about how we use navigation data, access our Privacy Policy.","usage_terms_topic12":"12. Support","usage_terms_topic12_paragraph1":"Applicants can contact Gupy Support by opening a ticket through https://gupy.zendesk.com/hc/pt-br/requests/new. Contacts will also be answered by email, from Monday to Friday, from 9am to 6pm, except holidays.","usage_terms_topic12_paragraph2":"You can also find several information in our Help Center: https://gupy.zendesk.com/hc/pt-br.","usage_terms_topic13":"13. GUPY's Responsibility","usage_terms_topic13_paragraph1":"GUPY is responsible for:","usage_terms_topic13_paragraph1_item1":"a) acting as an intermediary between companies that publish job offers or talent pool openings and Candidates that publish resumes, build profiles, search for job offers, perform the tests made available by the tool and evaluate, anonymously or not, the companies where they work or have worked;","usage_terms_topic13_paragraph1_item2":"b) offer the r\xE9sum\xE9 qualification system for the requirements of the job offer presented by the COMPANY and searched by the Candidates with the use of its technology. The qualification is made by mathematical algorithms that use the information made available by the USERS, reason why GUPY is only responsible for the results of the tool if the published information is true.","usage_terms_topic13_paragraph2":"GUPY is NOT responsible for:","usage_terms_topic13_paragraph2_item1":"a) Job opportunities presented by the COMPANIES","usage_terms_topic13_paragraph2_item1_description":"The opening of job offers is the exclusive responsibility of the COMPANY, and GUPY is not responsible for the quality, safety or legality of the job opportunities presented, the veracity or accuracy of the listings and the ability of the companies to offer opportunities for candidates. The publication of job offers and their content are the responsibility of the COMPANY, including with regard to the hiring model.","usage_terms_topic13_paragraph2_item2":"b) Data informed by Candidates","usage_terms_topic13_paragraph2_item2_description":"The data informed by the Candidate are of his/her exclusive responsibility, and GUPY can not be held responsible for any mistake in filling out the data or their untruthfulness and for the consequences that may arise from this, such as the non-selection of the Candidate for a particular recruitment process, subsequent disqualification from the recruitment process in which he/she was participating or the impossibility of contacting the Candidate by the COMPANY due to the fact that direct contact information (telephone and e-mail) of the Candidate are hidden or incomplete.","usage_terms_topic13_paragraph2_item3":"c) Choice of Candidates for any step of the recruitment process","usage_terms_topic13_paragraph2_item3_description":"GUPY has no participation in the recruitment process, qualification and choice that the COMPANIES make in their process, which are the exclusive responsibility of the COMPANIES.","usage_terms_topic13_paragraph2_item4":"d) Elimination of Candidates in the recruitment process","usage_terms_topic13_paragraph2_item4_description":"For the reasons already indicated above, GUPY is also not responsible for the elimination of Candidates in the recruitment process of the COMPANY","usage_terms_topic13_paragraph2_item5":"e) Direct Negotiation between Candidate and COMPANY","usage_terms_topic13_paragraph2_item5_description":"GUPY is not involved in the negotiation between COMPANIES and Candidates and is not responsible for the selection of Candidates or for delays in the recruitment process. GUPY is not responsible for any information exchanged in direct contact between COMPANIES and Candidates via email or telephone.","usage_terms_topic13_paragraph2_item6":"f) Links to other sites","usage_terms_topic13_paragraph2_item6_description":"The GUPY Platform contains links to third-party websites, provided for your convenience and not as an endorsement by GUPY of the content on those sites. GUPY has no control over and is not responsible for the content, privacy policies or practices of third party websites and will not comment on the content or accuracy of third party materials. If you access the link, you do so at your own risk.","usage_terms_topic14":"14. Price","usage_terms_topic14_paragraph1":"Your basic registration on the GUPY Platform is free and includes the creation of a page with personal information on the Gupy website, the possibility of performing tests for profile mapping and work style and the possibility of viewing the companies and jobs registered that fit your profile.","usage_terms_topic14_paragraph2":"GUPY reserves the right to institute, modify, increase or eliminate rates at any time, always notifying previously the USERS, who will decide to hire or not the services for the price charged or updated.","usage_terms_topic15":"15. Accept","usage_terms_topic15_paragraph1":"BY AGREEING TO THESE TERMS AND INITIATING THE USE OF THE GUPY PLATFORM, YOU UNDERTAKE TO RESPECT THE CONDITIONS SET OUT IN AN IRREVOCABLE AND IRREVERSIBLE MANNER, AS WELL AS TO USE IN A BENEFICIAL AND LEGAL MANNER THE SERVICES OFFERED BY THE GUPY PLATFORM.","usage_terms_topic16":"16. Forum","usage_terms_topic16_paragraph1":"Conflicts arising from these Terms shall be resolved in the Central Forum of the County of S\xE3o Paulo/SP.","usage_terms_last_update":"Last Updated on April 19, 2021.","terms_and_policy_update_description":"We understand that by continuing to use our products, you agree to the new terms. To consult them, simply access these links: {termsLink} and {policyLink}.","terms_and_policy_update_title":"We have updated our terms of use and privacy policy","change_email_reached_max_attempts":"Changing your email was blocked after three unsuccessful attempts. Please try again in {minutes} minutes ({timeStamp})","main_activities":"Main activities","degree_level":"Education","achievements":"Achievements","achievement":"Achievement","languages":"Languages","curriculum-register-social-networks-title":"Social network profiles","no_info":"No information","years":"years","toast_error":"Unable to download your data, please wait a moment and try again.","toast_success":"Your account details have been successfully downloaded!","zipCode":"Zip Code","old_pending_confirm_email":"The e-mail <strong>{email}</strong> has not been confirmed. Request confirmation to ensure communication between you and the company. <a href=\\"/candidates/profile/send-confirm-email\\">Click here</a> to receive a confirmation link in your email. If this is not your best email, you can update this information below.","pending_email_description":"The email <strong>{email}</strong> has not yet been confirmed. To confirm, check your inbox and click on the link that was sent to you. Thus, you guarantee communication between you and the company. Remember to also check the SPAM folder.","expired_email_validation_token":"<strong> Important </strong>: The link sent for the email confirmation has expired. <a href=\\"/candidates/profile/send-confirm-email\\">Click here</a> to receive a new confirmation link in your email. If this is not your best email, you can update this information below.","redirect_to_login_hint":"After setting your new password, <b>you will be redirected to login.</b>","profile-photo-removal-dialog-description":"The option to include a photo in the resume has been removed from the platform to <strong> prioritize your professional experiences</strong> over potential biases related to appearance.","candidate_admission_deleting_alert":"We are unable to delete your account because you have initiated an admission process with <strong>{addmisionCompanyName}<strong>.","email_validation_verification_pending_message":"The email address validation link may take a while to deliver. Remember to check your SPAM box as well. If within 24 hours the link does not reach your email address, <a href=\\"https://gupy.zendesk.com/hc/en-001\\">contact our support</a>.","email_change_verification_pending_message":"The link to validate your email changes may take a while to deliver. Remember to check your SPAM box as well. If within 24 hours the link does not reach your email address, you can change your email address again or <a href=\\"https://gupy.zendesk.com/hc/en-001\\">contact our support</a>.","email_changed_successfully":"The verification and alteration to the e-mail <strong>{email}</strong> was completed. Remember to use it on the next login to access the platform correctly.","manage_privacy_setting_know_more_description":"When you apply for a vacancy, you automatically start to do\\n               part of the recruiting company\u2019s Talent Bank. In this way, <strong>besides communications\\n               about the progress of your processes</strong>, you will start to receive messages about new vacancies and\\n               Talent Bank updates.","manage_privacy_setting_know_more_subdescription":"By <strong> deleting information\\n              shared with the company</strong>, you will no longer receive any messages and will have\\n              your applications are closed.","manage_privacy_settings_title":"Manage Privacy Settings","manage_privacy_settings":"Manage Privacy Settings","manage_privacy_setting_description":"For each company listed, you can disable notifications, as well as delete linked data when you are no longer interested in sharing it.","manage_privacy_setting_no_linked_companies_title":"No companies listed","manage_privacy_setting_no_linked_companies_description":"It looks like you haven\u2019t applied for any jobs yet, so there are no companies to show here.","manage_privacy_setting_know_more_title":"Access to personal data by the recruiting company","unbind_company_request_message":"Request made successfully. Within 10 days, we will remove your data shared with the company.","unbind_compan_collapse_expand_aria_label":"expand unbind company","unbind_company_delete_bound_data":"Delete bound data","unbind_company_title":"Deletion of data shared with the company: ","unbind_company_confirm_unbind":"Delete shared data","unbind_company_group_confirm_unbind":"Delete shared data","unbind_company_keep_bound":"Keep the data","unbind_company_group_keep_bound":"Keep the data","unauthorized_unbind_company_title":"It is not possible to delete your data at this time.","unauthorized_unbind_company_description":"You have been hired for a job within the company less than 30 days ago. After this period, you can request the deletion of your data again.","unbind_company_options_danger":"You were hired less than 30 days ago and you can only request deletion of your data with that company after that period.","unbind_company_option_unbind_group":"Delete from all companies","unbind_company_option_unbind_company":"Delete from this company only","unbind_company_option_unbind_company_confirm":"Yes, delete it","unbind_company_cancel_consent":"Cancel exclusion","unbind_company_cancel_dialog":"Would you like to stop the data deletion process with","unbind_company_cancel_confirm":"Yes, stop","unbind_company_cancel_close":"Do nothing","unbind_company_in_process":"Company in deletion process","unbind_icon_aria_label":"","unbind_cancel_toast_success":"Deletion request successfully canceled","unbind_cancel_toast_error":"An error occurred. Please try again.","unbind_company_description":"Read and mark the following information so you are aware\\n                of the action and can continue with the exclusion:","unbind_company_check_item_1":"I understand that my profile will<strong>be removed from applications\\n                active and I will not be able to apply for previously applied positions</strong>.\\n                (You have {numberOfActiveApplications} currently active applications\\n                for the company)","unbind_company_check_item_2":"I understand that the <strong>deletion will be within 10 days</strong> and if\\nrefers to my shared data regarding the selection processes, not\\nimpacting any ongoing admission process.","unbind_company_check_item_3":"I understand that<strong>I will continue to receive communication\\n                  of this group of companies until the request for deletion from this group</strong>.","unbind_company_check_item_4":"I understand that if I apply to the company\u2019s vacancies <strong>in up to 10\\ndays after deletion</strong> my previous data <strong>will be rescued</strong>\\nand active applications will return with status of \u201CWithdrawal\u201D. After the deadline,\\nthis history will not be redeemed.","unbind_company_group_title":"Deletion of data shared with the group: {companyName}","unbind_company_group_description":"By deleting all your data shared with the group, your profile\\n              will be unregistered from the Talent Pool and the <strong>{numberOfActiveApplications}\\n              Applications that are active will also be removed</strong>.","unbind_company_group_subdescription":"<strong>Are you sure about this?</strong> If yes, read and mark the\\n              information below so that you are aware of the action and can proceed with the deletion.","unbind_company_group_check_item_1":"I understand that my profile will <strong>be removed from active applications\\n                and I will not be able to apply for the same vacancies again</strong>.","unbind_company_group_check_item_2":"I understand that the <strong>deletion will be within 10 days</strong> and if\\n                refers to my shared data regarding the selection processes, not\\n                impacting any ongoing admission process.","unbind_company_group_check_item_3":"I understand that <strong>I will no longer receive communications from this group of\\n                companies.</strong>","unbind_company_group_check_item_4":"I understand that if I apply for vacancies in this group <strong>in up to 10\\n                days after deletion</strong> my previous data <strong>will be rescued</strong>\\n                 and active applications will return with status of \u201CWithdrawal\u201D. After the deadline,\\n                  this history will not be redeemed.","unbind_company_group_check_item_5":"I understand that if I reapply for group vacancies after\\n                deletion, <strong>I will return to the company\u2019s Talent Bank and the company will have access to\\n                my data</strong>.","unbind_company_options_title":"This company belongs to the {companyName} group of companies","unbind_company_options_description":"Have you previously applied for jobs at the following companies\\n              owned by {companyName}:","unbind_company_options_subdescription_part1":"Do you want to delete the data linked <strong>only with the company\\n              {careerPageName}</strong>","unbind_company_options_subdescription_part2":"or <strong>all companies in the {companyName} group that do not have\\n              recent hire</strong>","invalid_confirmation_email_or_token":"Your link has expired. Please try to change your e-mail again.","first-name-label":"Name","change-password":"Change password","data_saved_successfully":"Data stored successfully!","password_changed_successfully":"Your password has been altered successfully!","personal_register":"Registration","personal_register_description":"Change your name or password here, if you need to. :)","current_password_label":"Current password","new_password_label":"New password","mobile_phone_not_valid_error":"Invalid cell phone number.","change_register_image_label":"","delete_button_text":"Delete photo","invalid_photo_image_size_1mb":"Your photo cannot be larger than 1MB","invalid_photo_extesion_jpg_png":"Invalid file format. Files must be .jpg, .jpeg or .png","candidate_deleting_error":"This e-mail or document is linked to an account which is being deleted. Please try another e-mail or document.","current_password_dont_match":"Current password doesn't match the registered password","change_email_form_title":"Change email","change_email_form_p1":"Your registered email is","change_email_form_p2":"What will be the new email?","change_email_form_p3":"Remember: the email is one of the main communication channels between you and the company, always keep it updated!","change_email_form_input_new_email":"New email","change_email_form_input_new_email_tip":"You will receive a confirmation link in the new email","change_email_form_input_confirmation_email":"Repeat email","change_email_form_input_confirmation_email_tip":"Enter your new email again","change_email_result_title":"Almost there","change_email_result_p1":"There is little left to finish changing your email.","change_email_result_p2":"Now you need to go to your inbox and click on the link that was sent to the email address you provided:","change_email_result_p3":"As long as the new address is not confirmed, your account will remain linked to the old email.","change_email_result_p4":"The link sent is valid for 24 hours. Remember to check your spam folder.","change_email_result_back_button":"Back to profile","cv_download":"Download my CV","name_type_title":"Name you prefer to use:","account_data_title":"Set up your account and information","change_profile":"Change profile data","change_profile_subtitle":"Change your email, password or other personal information.","manage_privacy_settings_subtitle":"Configure your privacy and communications preferences.","delete_account":"Delete Gupy Account","delete_account_subtitle":"Permanently remove your Gupy platform account.","download_account_data":"Download your account data","download_account_data_subtitle":"Create a copy of your profile and resume data.","unknown_form_validation_error":"Unknown error!","email_verified_successfully_title":"Email verified successfully","email_verification__expired_title":"This link has expired","email_verification__expired_validation_fail":"The link to validate your email address has expired. Request a new validation link.","email_verification__expired_change_fail":"The link to validate your email changes has expired. You can continue using the platform with your current email address or request a new validation link.","email_verification_pending_title":"A link has already been or is being sent to you","email_sent_successfully":"Link sent! Check your inbox and spam folder to confirm your e-mail","confirm_email_click_button":"Click here","reason_for_no_display_profile_photo":"Understand why we don't display the profile picture","profile_photo_removal_dialog_title":"Profile picture removal","containers/user-profile/birthdate-tooltip":"This information is requested to ensure that you meet the minimum age requirement (14 years) to participate in the companies\u2019 selection processes.","manage_talent_portal_title":"Manage sharing with the Gupy Talent Pool","manage_talent_portal_heading":"Manage sharing with the Gupy Talent Pool","manage_talent_portal_subtitle":"Configure your resume sharing preferences with the Gupy Talent Pool","cv_download_file_name":"my-cv-gupy-{date}.pdf","talent_portal_dialog_see_more_first_paragraph":"The Gupy Talent Pool is <strong>the gateway to new opportunities.</strong>","talent_portal_title":"Gupy Talent Pool","talent_portal_first_paragraph":"Definitions about data sharing and applications.","talent_portal_phrase_visit_our":"Visit our","talent_portal_and":"and","talent_portal_phrase_see_more":"to learn more.","talent_portal_link_terms_of_use":"Terms of use","talent_portal_collapse_text":"It allows all companies to view the resumes of participating people and invite them to selection processes carried out at Gupy.","talent_portal_collapse_aria_label":"Expand Talent Portal configuration","talent_portal_collapse_image_aria_label":"Collapse icon representing the Gupy Talent Pool","talent_portal_collapse_curriculum_switch":"Share my resume","talent_portal_collapse_diversity_switch":"Share my diversity data","talent_portal_collapse_switch_checked":"Enabled","talent_portal_collapse_switch_not_checked":"Disabled","talent_portal_toast_curriculum_error":"Failed to enable \\"Share my curriculum\\" Please try again","talent_portal_toast_diversity_error":"Failed to enable \\"Share my diversity data\\" Please try again","talent_portal_dialog_see_more_alt_image":"Image representing the Gupy Talent Pool","talent_portal_dialog_see_more_what_is_talent_portal":"What is the Gupy Talent Pool?","talent_portal_dialog_see_more_second_paragraph":"By sharing your resume, you increase your visibility and allow companies to find your profile.","talent_portal_dialog_see_more_third_paragraph":"Gupy\u2019s artificial intelligence can also automatically recommend your profile to job openings that match your experience, connecting you to the best opportunities on the market.","talent_portal_searching_for_information":"Searching for information from the gupy talent pool.","candidate_pending_confirm_email":"Your email {strongEmail} has not been confirmed yet. {link} to receive the confirmation li